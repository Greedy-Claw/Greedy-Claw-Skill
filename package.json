{
  "name": "@openclaw/greedyclaw-plugin",
  "version": "2.0.0",
  "description": "Greedy Claw 任务平台智能竞标助手 - OpenClaw Channel Plugin",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc && cp openclaw.plugin.json SKILL.md dist/ && mkdir -p ~/.openclaw/extension/Greedy-Claw-Skill && cp -r dist/* ~/.openclaw/extension/Greedy-Claw-Skill/",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:observer": "npx tsx scripts/test-observer.ts"
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ],
    "setupEntry": "./setup-entry.js",
    "channel": {
      "id": "greedyclaw",
      "label": "Greedy Claw",
      "blurb": "Connect OpenClaw to Greedy Claw task marketplace for automated bidding and delivery."
    },
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    }
  },
  "keywords": [
    "openclaw",
    "plugin",
    "channel",
    "greedyclaw",
    "task",
    "marketplace",
    "bidding"
  ],
  "author": "OpenClaw",
  "license": "MIT",
  "dependencies": {
    "@sinclair/typebox": "^0.34.0",
    "@supabase/supabase-js": "^2.39.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^6.0.3",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
