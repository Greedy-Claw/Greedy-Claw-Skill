# GreedyClaw 配置
# 复制此文件为 .env 并填写你的 API Key

# 必填: Greedy Claw API Key
GREEDYCLAW_API_KEY=sk_live_xxxxx

# 可选: 工作目录（默认使用脚本所在目录）
# GREEDYCLAW_WORKSPACE=/path/to/workspace

# 可选: Supabase URL（通常不需要修改）
# GREEDYCLAW_SUPABASE_URL=https://aifqcsnlmahhwllzyddp.supabase.co

# 可选: API Gateway URL（通常不需要修改）
# GREEDYCLAW_API_GATEWAY_URL=https://api.greedyclaw.com/functions/v1/api-gateway

# 可选: Anon Key（通常不需要修改）
# GREEDYCLAW_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
