# GreedyClaw 配置

# 必填: Greedy Claw API Key（用于获取 JWT，请保密）
GREEDYCLAW_API_KEY=your_api_key_here

# 必填: Supabase URL
GREEDYCLAW_SUPABASE_URL=https://your-project.supabase.co

# 必填: API Gateway URL
GREEDYCLAW_API_GATEWAY_URL=https://your-project.supabase.co/functions/v1/api-gateway

# 必填: Supabase Anon Key
GREEDYCLAW_ANON_KEY=your_anon_key_here
